rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'jacmwaniki@gmail.com';
    }
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isOwnerOf(businessId) {
      return isSignedIn()
        && me().businessId == businessId
        && me().role == 'owner';
    }
    function isManagerOf(businessId, branchId) {
      return isSignedIn()
        && me().businessId == businessId
        && me().role == 'manager'
        && me().branchId == branchId;
    }
    function isSalesOf(businessId, branchId) {
      return isSignedIn()
        && me().businessId == businessId
        && me().role == 'sales_person'
        && me().branchId == branchId;
    }
    function isStaffOf(businessId, branchId) {
      return isSignedIn()
        && me().businessId == businessId
        && me().branchId == branchId;
    }
    function isAnyStaffOf(businessId) {
      return isSignedIn() && me().businessId == businessId;
    }

    // Default deny for safety
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Users ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn()
        && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && !request.resource.data.diff(resource.data)
            .affectedKeys().hasAny(['role','businessId','branchId']);
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    // ── Businesses ─────────────────────────────────────────
    match /businesses/{businessId} {
      allow read: if isAnyStaffOf(businessId) || isSuperAdmin();
      allow create: if isSignedIn();
      allow update: if isOwnerOf(businessId)
        && !request.resource.data.diff(resource.data)
            .affectedKeys().hasAny(['status']);
      allow update, delete: if isSuperAdmin();

      // ── Categories (business-level, shared) ────────────
      match /categories/{categoryId} {
        allow read: if isAnyStaffOf(businessId) || isSuperAdmin();
        allow write: if isOwnerOf(businessId) || isSuperAdmin();
      }

      // ── Suppliers (business-level, shared) ─────────────
      match /suppliers/{supplierId} {
        allow read: if isAnyStaffOf(businessId) || isSuperAdmin();
        allow write: if isOwnerOf(businessId)
          || (isSignedIn() && isManagerOf(businessId, me().branchId))
          || isSuperAdmin();
      }

      // ── Stock Transfers (business-level) ───────────────
      match /stockTransfers/{transferId} {
        allow read: if isAnyStaffOf(businessId) || isSuperAdmin();
        allow create: if isAnyStaffOf(businessId);
        allow update: if isOwnerOf(businessId)
          || isManagerOf(businessId, resource.data.fromBranchId)
          || isManagerOf(businessId, resource.data.toBranchId)
          || isSuperAdmin();
        allow delete: if false;
      }

      // ── Branches ───────────────────────────────────────
      match /branches/{branchId} {
        allow read: if isAnyStaffOf(businessId) || isSuperAdmin();
        allow write: if isOwnerOf(businessId) || isSuperAdmin();

        // ── Staff (branch-scoped) ─────────────────────
        match /staff/{staffId} {
          allow read: if isOwnerOf(businessId)
            || isManagerOf(businessId, branchId)
            || isSuperAdmin();
          allow create, update: if isOwnerOf(businessId) || isSuperAdmin();
          allow delete: if isOwnerOf(businessId) || isSuperAdmin();
        }

        // ── Products (branch-scoped) ──────────────────
        match /products/{productId} {
          allow read: if isStaffOf(businessId, branchId) || isSuperAdmin();
          allow write: if isOwnerOf(businessId)
            || isManagerOf(businessId, branchId)
            || isSuperAdmin();
        }

        // ── Transactions (branch-scoped) ──────────────
        match /transactions/{transactionId} {
          allow read: if isOwnerOf(businessId)
            || isManagerOf(businessId, branchId)
            || isSuperAdmin()
            || (isSalesOf(businessId, branchId)
                && resource.data.cashierId == request.auth.uid);
          allow create: if isStaffOf(businessId, branchId)
            && request.resource.data.cashierId == request.auth.uid;
          allow update: if isOwnerOf(businessId)
            || isManagerOf(businessId, branchId)
            || isSuperAdmin();
          allow delete: if false;

          match /payments/{paymentId} {
            allow read: if isOwnerOf(businessId)
              || isManagerOf(businessId, branchId)
              || isSuperAdmin();
            allow create: if isStaffOf(businessId, branchId);
            allow update, delete: if false;
          }
        }

        // ── Stock Movements (branch-scoped) ───────────
        match /stockMovements/{movementId} {
          allow read: if isStaffOf(businessId, branchId) || isSuperAdmin();
          allow create: if isOwnerOf(businessId)
            || isManagerOf(businessId, branchId)
            || isSuperAdmin();
          allow update, delete: if false;
        }

        // ── Expenses (branch-scoped) ──────────────────
        match /expenses/{expenseId} {
          allow read: if isStaffOf(businessId, branchId) || isSuperAdmin();
          allow create, update: if isOwnerOf(businessId)
            || isManagerOf(businessId, branchId)
            || isSuperAdmin();
          allow delete: if isOwnerOf(businessId) || isSuperAdmin();
        }

        // ── Customers (branch-scoped) ─────────────────
        match /customers/{customerId} {
          allow read, write: if isOwnerOf(businessId)
            || isManagerOf(businessId, branchId)
            || isSuperAdmin();
        }

        // ── Notifications (branch-scoped) ─────────────
        match /notifications/{notificationId} {
          allow read: if isStaffOf(businessId, branchId) || isSuperAdmin();
          allow create: if isStaffOf(businessId, branchId);
          allow update: if isSignedIn()
            && request.auth.uid == resource.data.userId;
          allow delete: if false;
        }

        // ── Audit Log (branch-scoped, append-only) ────
        match /auditLog/{logId} {
          allow read: if isOwnerOf(businessId)
            || isManagerOf(businessId, branchId)
            || isSuperAdmin();
          allow create: if isStaffOf(businessId, branchId);
          allow update, delete: if false;
        }
      }
    }

    // ── Super Admin ────────────────────────────────────────
    match /superAdmin/{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
