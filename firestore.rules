rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'jacmwaniki@gmail.com';
    }

    function userExists() {
      // Use existsAfter for cross-doc validation during creation/atomic batches
      return existsAfter(/databases/$(database)/documents/users/$(request.auth.uid)) || 
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwnerOf(businessId) {
      return isSignedIn()
        && (me().businessId == businessId)
        && (me().role == 'owner');
    }

    function isManagerOf(businessId, branchId) {
      return isSignedIn()
        && (me().businessId == businessId)
        && (me().role == 'manager')
        && (me().branchId == branchId || branchId == 'any');
    }

    function isSalesOf(businessId, branchId) {
      return isSignedIn()
        && (me().businessId == businessId)
        && (me().role == 'sales_person')
        && (me().branchId == branchId);
    }

    function isStaffOf(businessId) {
      return isSignedIn()
        && (me().businessId == businessId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Users ───────────────────────────────────────────────
    match /users/{uid} {
      // Allow read if user is self, superadmin, or same business staff
      allow read: if isSignedIn()
        && (request.auth.uid == uid || isSuperAdmin() || (isStaffOf(resource.data.businessId)));

      // Allow create if user is self OR if creator is the owner of the business being assigned
      allow create: if isSignedIn()
        && (
          request.auth.uid == uid || 
          isOwnerOf(request.resource.data.businessId)
        );

      // Staff can update self (limited), Owners can update staff in their biz
      allow update: if isSignedIn()
        && (
          isSuperAdmin() ||
          (request.auth.uid == uid && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'businessId', 'branchId'])) ||
          (isOwnerOf(resource.data.businessId) && request.resource.data.businessId == resource.data.businessId)
        );

      allow delete: if isSuperAdmin() || (isSignedIn() && isOwnerOf(resource.data.businessId));
    }

    // ─── Businesses ──────────────────────────────────────────
    match /businesses/{businessId} {
      allow read: if isSuperAdmin()
        || isStaffOf(businessId)
        || (resource.data.ownerEmail == request.auth.token.email);

      allow list: if isSignedIn();
      allow create: if isSignedIn();

      allow update: if isOwnerOf(businessId)
        && !request.resource.data.diff(resource.data)
            .affectedKeys().hasAny(['status']);

      allow update, delete: if isSuperAdmin();

      // ─── Sub-collections ───

      match /branches/{branchId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow write: if isOwnerOf(businessId) || isSuperAdmin();
      }

      match /products/{productId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow write: if isOwnerOf(businessId)
          || (isSignedIn() && isManagerOf(businessId, request.resource.data.get('branchId', 'all')))
          || (resource != null && isManagerOf(businessId, resource.data.get('branchId', 'all')))
          || isSuperAdmin();
      }

      match /transactions/{transactionId} {
        allow read: if isOwnerOf(businessId)
          || isSuperAdmin()
          || isManagerOf(businessId, resource.data.branchId)
          || (isSalesOf(businessId, resource.data.branchId)
              && resource.data.cashierId == request.auth.uid);

        allow create: if isStaffOf(businessId)
          && request.resource.data.cashierId == request.auth.uid;

        allow update: if isOwnerOf(businessId)
          || isManagerOf(businessId, resource.data.branchId)
          || isSuperAdmin();

        allow delete: if false;
      }

      match /auditLog/{logId} {
        allow read: if isOwnerOf(businessId)
          || isSuperAdmin()
          || isManagerOf(businessId, me().branchId);
        allow create: if isStaffOf(businessId);
        allow update, delete: if false;
      }

      match /expenses/{expenseId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow create: if isOwnerOf(businessId) 
          || (isSignedIn() && isManagerOf(businessId, request.resource.data.branchId)) 
          || isSuperAdmin();
        allow update: if isOwnerOf(businessId) 
          || (resource != null && isManagerOf(businessId, resource.data.branchId)) 
          || isSuperAdmin();
        allow delete: if isOwnerOf(businessId) || isSuperAdmin();
      }

      match /customers/{customerId} {
        allow read, write: if isOwnerOf(businessId)
          || (isSignedIn() && isManagerOf(businessId, 'any'))
          || isSuperAdmin();
      }

      match /stockTransfers/{transferId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow create: if isStaffOf(businessId);
        allow update: if isOwnerOf(businessId)
          || isManagerOf(businessId, resource.data.fromBranchId)
          || isManagerOf(businessId, resource.data.toBranchId)
          || isSuperAdmin();
        allow delete: if false;
      }

      match /stockMovements/{movementId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow create: if isOwnerOf(businessId)
          || (isSignedIn() && isManagerOf(businessId, request.resource.data.branchId))
          || isSuperAdmin();
        allow update, delete: if false;
      }

      match /suppliers/{supplierId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow write: if isOwnerOf(businessId) || isSuperAdmin();
      }

      match /notifications/{notificationId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow create: if isStaffOf(businessId);
        allow update: if isSignedIn()
          && request.auth.uid == resource.data.userId;
        allow delete: if false;
      }
    }

    match /superAdmin/auditLog/entries/{entryId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSuperAdmin();
    }

    match /superAdmin/{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
