rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'jacmwaniki@gmail.com';
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwnerOf(businessId) {
      return isSignedIn()
        && userExists()
        && me().businessId == businessId
        && me().role == 'owner';
    }

    function isManagerOf(businessId, branchId) {
      return isSignedIn()
        && userExists()
        && me().businessId == businessId
        && me().role == 'manager'
        && me().branchId == branchId;
    }

    function isSalesOf(businessId, branchId) {
      return isSignedIn()
        && userExists()
        && me().businessId == businessId
        && me().role == 'sales_person'
        && me().branchId == branchId;
    }

    function isStaffOf(businessId) {
      return isSignedIn()
        && userExists()
        && me().businessId == businessId;
    }

    function isManagerOrOwner(businessId, branchId) {
      return isOwnerOf(businessId)
        || isManagerOf(businessId, branchId);
    }

    // Default deny for safety
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Users ───────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn()
        && (request.auth.uid == uid || isSuperAdmin());

      allow create: if isSignedIn()
        && request.auth.uid == uid;

      // Registration update: Allow setting businessId and owner role if user has no role yet
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && (
          isSuperAdmin() ||
          (!resource.data.keys().has('role')) ||
          (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'businessId', 'branchId']))
        );

      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    // ─── Businesses ──────────────────────────────────────────
    match /businesses/{businessId} {
      // PERMISSIVE READ: Allow reading if staff, admin, OR if the user is the owner by email (Registration flow)
      allow read: if isSuperAdmin()
        || isStaffOf(businessId)
        || (resource.data.ownerEmail == request.auth.token.email);

      // Required for collection-level queries during registration
      allow list: if isSignedIn();

      allow create: if isSignedIn();

      allow update: if isOwnerOf(businessId)
        && !request.resource.data.diff(resource.data)
            .affectedKeys().hasAny(['status']);

      allow update, delete: if isSuperAdmin();


      // ─── Sub-collections ───

      match /branches/{branchId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow write: if isOwnerOf(businessId) || isSuperAdmin();
      }

      match /products/{productId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow write: if isOwnerOf(businessId)
          || (isSignedIn() && isManagerOf(businessId, request.resource.data.get('branchId', 'all')))
          || (resource != null && isManagerOf(businessId, resource.data.get('branchId', 'all')))
          || isSuperAdmin();
      }

      match /transactions/{transactionId} {
        allow read: if isOwnerOf(businessId)
          || isSuperAdmin()
          || isManagerOf(businessId, resource.data.branchId)
          || (isSalesOf(businessId, resource.data.branchId)
              && resource.data.cashierId == request.auth.uid);

        allow create: if isStaffOf(businessId)
          && request.resource.data.cashierId == request.auth.uid;

        allow update: if isOwnerOf(businessId)
          || isManagerOf(businessId, resource.data.branchId)
          || isSuperAdmin();

        allow delete: if false;
      }

      match /auditLog/{logId} {
        allow read: if isOwnerOf(businessId)
          || isSuperAdmin()
          || (userExists() && isManagerOf(businessId, me().branchId));
        allow create: if isStaffOf(businessId);
        allow update, delete: if false;
      }

      match /expenses/{expenseId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow create: if isOwnerOf(businessId) || isManagerOf(businessId, request.resource.data.branchId) || isSuperAdmin();
        allow update: if isOwnerOf(businessId) || isManagerOf(businessId, resource.data.branchId) || isSuperAdmin();
      }

      match /customers/{customerId} {
        allow read, write: if isOwnerOf(businessId)
          || isManagerOf(businessId, 'any')
          || isSuperAdmin();
      }

      match /stockTransfers/{transferId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow create: if isStaffOf(businessId);
        allow update: if isOwnerOf(businessId)
          || isManagerOf(businessId, resource.data.fromBranchId)
          || isManagerOf(businessId, resource.data.toBranchId)
          || isSuperAdmin();
        allow delete: if false;
      }

      match /stockMovements/{movementId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow create: if isOwnerOf(businessId)
          || isManagerOf(businessId, request.resource.data.branchId)
          || isSuperAdmin();
        allow update, delete: if false;
      }

      match /suppliers/{supplierId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow write: if isOwnerOf(businessId)
          || isSuperAdmin();
      }

      match /notifications/{notificationId} {
        allow read: if isStaffOf(businessId) || isSuperAdmin();
        allow create: if isStaffOf(businessId);
        allow update: if isSignedIn()
          && request.auth.uid == resource.data.userId;
        allow delete: if false;
      }
    }

    match /superAdmin/auditLog/entries/{entryId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSuperAdmin();
    }

    match /superAdmin/{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
